NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_APP_URL=https://your-app-domain.com
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_app_client_secret
SHOPIFY_WEBHOOK_SECRET=optional_leave_blank_to_fall_back_to_SHOPIFY_API_SECRET

# Only use this for a one-store custom distribution test app.
# Leave it blank or unset for the public Shopify app so installs are dynamic per store.
# SHOPIFY_APP_INSTALL_URL=https://admin.shopify.com/oauth/install_custom_app?...
